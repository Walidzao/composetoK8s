Vagrant.configure("2") do |config|
  # Base box configuration - Ubuntu ARM for Apple Silicon Macs
  config.vm.box = "spox/ubuntu-arm"
  config.vm.box_version = "1.0.0"

  # Private network configuration - allows host-only access to the VM
  config.vm.network "private_network", ip: "192.168.56.11"

  # Sync the parent vprofile-project directory to /vprofile-project in the VM
  config.vm.synced_folder "../../", "/vprofile-project"

  # VMware Desktop provider configuration (for macOS with VMware Fusion/Parallels)
  config.vm.provider "vmware_desktop" do |vmware|
    vmware.gui = true
    vmware.memory = 2048
    vmware.allowlist_verified = true
    vmware.linked_clone = false
    vmware.vmx["ethernet0.virtualdev"] = "vmxnet3"
    vmware.ssh_info_public = true
  end

  # Provision VM with Docker and Docker Compose
  config.vm.provision "shell", inline: <<-SHELL
    #!/bin/bash
    set -e

    # Update package list and install prerequisites
    sudo apt-get update

    # Install Docker
    curl -fsSL https://get.docker.com | sh

    # Ensure vagrant user can run docker without sudo
    sudo usermod -aG docker $USER

    # Install Docker Compose (for ARM64/Ubuntu)
    DOCKER_COMPOSE_VERSION="1.29.2"
    sudo curl -L "https://github.com/docker/compose/releases/download/${DOCKER_COMPOSE_VERSION}/docker-compose-$(uname -s)-$(uname -m)" \
      -o /usr/local/bin/docker-compose
    sudo chmod +x /usr/local/bin/docker-compose

    # Print versions
    docker --version
    docker-compose --version

    echo "Docker and Docker Compose have been installed."
  SHELL
end
